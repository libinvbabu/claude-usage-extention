{
  "name": "claude-usage-pace",
  "version": "0.1.0",
  "description": "Inline pacing helper for Claude usage — session headroom, weekly pace, and Claude Code task guidance. Local-only.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:app && npm run build:content -- --watch",
    "build": "tsc --noEmit && npm run build:app && npm run build:content",
    "build:app": "vite build",
    "build:content": "vite build --config vite.content.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
